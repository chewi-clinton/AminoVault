SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname
DB_SSL_REQUIRE=False

# S3-compatible media storage (MinIO, R2, or AWS S3)
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=aminovault
S3_ENDPOINT_URL=https://minio.your-domain.com
S3_CUSTOM_DOMAIN=

# Brevo (Sendinblue) SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your-brevo-login-email
BREVO_SMTP_KEY=your-brevo-smtp-key

# Store emails
STORE_OWNER_EMAIL=yomba.daniel@ictuniversity.edu.cm
STORE_FROM_EMAIL=noreply@aminovault.com
STORE_NAME=AminoVault

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
